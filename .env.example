# ─────────────────────────────────────────────────────────────────────────────
# Folio Bookstore — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# Public URL of this server. Used for OAuth callback URLs.
# Development : http://localhost:8080
# Production  : https://<your-app>.onrender.com  (set this in Render dashboard)
APP_URL=http://localhost:8080

# Public URL of the frontend, used for CORS (Access-Control-Allow-Origin) and
# for the session cookie to be accepted cross-site. Only needed when the
# frontend is deployed separately from this server (e.g. on Vercel) — if
# unset, it defaults to APP_URL (the monolith Render deploy, same origin).
# Production (Vercel) : https://<your-app>.vercel.app
CLIENT_URL=

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# Create a free cluster at https://cloud.mongodb.com
DB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/ecommerce?retryWrites=true&w=majority

# ── Session ───────────────────────────────────────────────────────────────────
# Used to sign express-session cookies and the MongoStore.
# Production: generate a strong random secret (minimum 32 characters).
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SECRET_KEY=change_this_to_a_long_random_secret_min_32_chars

# ── Email (optional) ─────────────────────────────────────────────────────────
# Required only for: password reset and inactive-user deletion notifications.
# Use a Gmail App Password (not your account password).
# Leave empty to disable email features gracefully.
GMAIL=
GMAIL_PASSWORD=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Test keys (sk_test_ / pk_test_) are safe for development.
# Replace with live keys (sk_live_ / pk_live_) for real payments.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxx

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
# Register an OAuth App at https://github.com/settings/developers
# Callback URL: <APP_URL>/auth/githubcallback
# Leave empty to disable GitHub login.
GITHUB_ID=
GITHUB_SECRET=

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Register credentials at https://console.cloud.google.com
# Callback URL: <APP_URL>/auth/googlecallback
# Leave empty to disable Google login.
GOOGLE_ID=
GOOGLE_SECRET=

# ── Folio Concierge / Librero IA ──────────────────────────────────────────────
# Controls which AI provider powers the Concierge chat feature.
# demo      : no external API calls — queries your own MongoDB catalog (default)
# openai    : future support (not yet implemented)
# anthropic : future support (not yet implemented)
AI_MODE=demo

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to true to block all write operations from the admin panel.
# Useful for public portfolio demos — prevents data modification.
# Production: set to false (or true if you want a read-only public demo).
DEMO_MODE=false
